{
  "name": "ReelFlip",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "backend:build": "npm --prefix backend run build",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:test": "npm --prefix backend run test",
    "backend:verify:parity": "npm --prefix backend run verify:parity",
    "backend:perf:baseline": "npm --prefix backend run perf:baseline",
    "backend:perf:check": "npm --prefix backend run perf:check",
    "backend:rollout:gate": "npm --prefix backend run rollout:gate",
    "backend:verify:migration": "npm --prefix backend run verify:migration",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run fmt:check && npm run android:build",
    "dev": "expo start --clear --dev-client --reset-cache",
    "doctor": "npx -y expo-doctor@latest",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "postinstall": "patch-package",
    "start": "expo start",
    "verify:android:debug": "npm run android:build && ./android/gradlew -p android :app:assembleDebug",
    "verify:android:release": "npm run android:build && ./android/gradlew -p android :app:assembleRelease",
    "verify:local": "tsc --noEmit && npm run lint:check && npm run fmt:check && npm run verify:android:debug",
    "web": "expo start --web"
  },
  "displayName": "ReelFlip",
  "description": "TikTok-style crypto trading app on Solana.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "mobile-wallet-adapter",
    "react-native",
    "solana-kit"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/dropdown-menu": "^1.2.0",
    "@solana-program/memo": "^0.10.0",
    "@solana/kit": "^5.5.0",
    "@tanstack/react-query": "^5.90.7",
    "@wallet-ui/core": "^3.1.0",
    "@wallet-ui/react-native-kit": "^3.1.0",
    "expo": "~54.0.23",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "js-base64": "^3.7.8",
    "lightweight-charts": "^5.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
