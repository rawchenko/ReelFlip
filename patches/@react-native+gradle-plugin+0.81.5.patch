+private fun resolveNodeExecutable(): String {
+  val nodeBinary = System.getenv("NODE_BINARY")?.takeIf { it.isNotBlank() && File(it).canExecute() }
+  if (nodeBinary != null) {
+    return nodeBinary
+  }
+
+  val homebrewNode = File("/opt/homebrew/bin/node")
+  if (homebrewNode.canExecute()) {
+    return homebrewNode.absolutePath
+  }
+
+  val localNode = File("/usr/local/bin/node")
+  if (localNode.canExecute()) {
+    return localNode.absolutePath
+  }
+
+  return "node"
+}
