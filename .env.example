# Expo app API base URL for the feed backend.
# Android emulator default: http://10.0.2.2:3001
# iOS simulator default: http://127.0.0.1:3001
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3001
EXPO_PUBLIC_CHART_FALLBACK_POLL_MS=10000
# EXPO_PUBLIC_SWAP_SKR_MINT=

# Activity tab local development mode.
# false (default): empty source
# true: seeded mock activity rows
EXPO_PUBLIC_ACTIVITY_DEV_MOCK=false
