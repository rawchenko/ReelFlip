HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
RUNTIME_MODE=dev
CACHE_REQUIRED=false
ALLOW_DEGRADED_START=false
REDIS_CONNECT_TIMEOUT_MS=1500

# Supabase token-domain persistence.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_REQUEST_TIMEOUT_MS=10000
SUPABASE_READ_ENABLED=false
SUPABASE_PREFER_READ_FIRST=false
SUPABASE_DUAL_WRITE_ENABLED=false
TOKEN_INGEST_INTERVAL_SECONDS=300
TOKEN_CANDLE_RETENTION_DAYS=14
ALERT_WEBHOOK_TIMEOUT_MS=3000
ALERT_WEBHOOK_RETRY_COUNT=2
ALERT_WEBHOOK_COOLDOWN_SECONDS=300
ALERT_FEED_SEED_RATE_THRESHOLD=0.4
ALERT_SUPABASE_FAILURE_RATE_THRESHOLD=0.2
ALERT_MIN_REQUESTS=20
# ALERT_WEBHOOK_URL=https://example.com/alerts

# Optional in dev. In production set CACHE_REQUIRED=true and configure REDIS_URL.
# REDIS_URL=redis://127.0.0.1:6379

FEED_CACHE_TTL_SECONDS=5
FEED_CACHE_STALE_TTL_SECONDS=30
FEED_DEFAULT_LIMIT=10
FEED_MAX_LIMIT=20
FEED_REFRESH_INTERVAL_SECONDS=30

DEXSCREENER_TIMEOUT_MS=5000
DEXSCREENER_SEARCH_QUERY=solana
DEXSCREENER_TOKEN_MINTS=

# BIRDEYE_API_KEY=
# BIRDEYE_TIMEOUT_MS=2500
# HELIUS_API_KEY=
HELIUS_DAS_URL=https://mainnet.helius-rpc.com
HELIUS_TIMEOUT_MS=2500
JUPITER_TAGS_TTL_MS=900000
FEED_ENRICHMENT_MAX_ITEMS=20
FEED_ENRICHMENT_CONCURRENCY=4
FEED_HELIUS_METADATA_ENABLED=false
FEED_MARKET_TTL_SECONDS=60
FEED_MARKET_CACHE_MAX_KEYS=2000
FEED_METADATA_TTL_SECONDS=43200
FEED_METADATA_CACHE_MAX_KEYS=2000
FEED_TRUST_TAGS_CACHE_MAX_KEYS=2000
FEED_ENRICHMENT_FAILURE_COOLDOWN_SECONDS=300
FEED_SPARKLINE_WINDOW_MINUTES=360
FEED_SPARKLINE_POINTS=72

CHART_ENABLED=true
CHART_INTERVAL_MS=1000
CHART_HISTORY_LIMIT=360
CHART_STALE_AFTER_MS=3000
CHART_PAIR_IDLE_TTL_MS=15000
CHART_MAX_PAIRS_PER_STREAM=3
CHART_MAX_ACTIVE_PAIRS_GLOBAL=256
CHART_BATCH_MAX_PAIRS=8
CHART_BOOTSTRAP_LIMIT=60
CHART_HISTORY_BACKFILL_ENABLED=true
CHART_HISTORY_WARMUP_TOP_PAIRS=10
CHART_HISTORY_PROVIDER=public
CHART_HISTORY_PROVIDER_FALLBACK=none
CHART_HISTORY_PROVIDER_TIMEOUT_MS=3000
CHART_HISTORY_BACKFILL_CONCURRENCY=4
CHART_STREAM_MAX_LEN=2000

RATE_LIMIT_FEED_PER_MINUTE=120
RATE_LIMIT_CHART_HISTORY_PER_MINUTE=240
RATE_LIMIT_CHART_STREAM_PER_MINUTE=30
RATE_LIMIT_IMAGE_PROXY_PER_MINUTE=60
