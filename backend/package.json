{
  "name": "reelflip-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "verify:parity": "node scripts/parity/feed_parity_check.mjs",
    "perf:baseline": "node scripts/perf/feed_p95_benchmark.mjs --mode capture-baseline",
    "perf:check": "node scripts/perf/feed_p95_benchmark.mjs --mode compare",
    "rollout:gate": "node scripts/rollout/evaluate_gate.mjs",
    "verify:migration": "npm run verify:parity && npm run perf:check && npm run rollout:gate"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "bs58": "^6.0.0",
    "fastify": "^5.7.4",
    "ioredis": "^5.8.1",
    "jose": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "autocannon": "^8.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
